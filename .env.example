# ============================================================
# SYUTAINβ V25 環境変数テンプレート
# コピーして .env にリネームし、実際の値を設定してください
# cp .env.example .env
# ============================================================

# ===== LLM API（必須：最低1つ）=====
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-proj-xxx
GEMINI_API_KEY=AIzaSyXxx
DEEPSEEK_API_KEY=sk-xxx
OPENROUTER_API_KEY=sk-or-v1-xxx

# ===== 情報収集 API =====
TAVILY_API_KEY=tvly-xxx
JINA_API_KEY=jina_xxx
YOUTUBE_API_KEY=AIzaSyXxx

# ===== Gmail API（OAuth2）=====
GMAIL_ALERTS_LABEL=your-alerts-label
GMAIL_RAKUTEN_LABEL=your-bank-label

# ===== 金融 API =====
WISE_API_TOKEN=xxx
WISE_PROFILE_ID=xxx
GMO_API_KEY=xxx
GMO_API_SECRET=xxx
BITBANK_API_KEY=xxx
BITBANK_API_SECRET=xxx

# ===== GitHub API =====
GITHUB_TOKEN=ghp_xxx

# ===== SNS API =====
X_API_KEY=xxx
X_API_SECRET=xxx
X_ACCESS_TOKEN=xxx
X_ACCESS_TOKEN_SECRET=xxx
X_BEARER_TOKEN=xxx
BLUESKY_HANDLE=yourname.bsky.social
BLUESKY_APP_PASSWORD=xxx
NOTE_EMAIL=xxx
NOTE_PASSWORD=xxx

# ===== 通知 =====
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# ===== 予算管理 =====
MONTHLY_API_BUDGET_JPY=2000
MONTHLY_INFO_BUDGET_JPY=15000
DAILY_API_BUDGET_JPY=80

# ===== Web UI =====
APP_PASSWORD=CHANGE_ME
APP_SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ===== データベース =====
DATABASE_URL=postgresql://localhost:5432/syutain_beta
CORE_DB_PATH=data/core.db
GTM_DB_PATH=data/gtm.db
LEARNING_DB_PATH=data/learning.db
API_DB_PATH=data/api.db
CHAT_DB_PATH=data/chat.db

# ===== NATS =====
NATS_URL=nats://localhost:4222

# ===== ノード設定（Tailscale IPを記入）=====
THIS_NODE=alpha
ALPHA_IP=100.xxx.xxx.xxx
ALPHA_URL=localhost:8000
BRAVO_IP=100.xxx.xxx.xxx
BRAVO_URL=100.xxx.xxx.xxx
CHARLIE_IP=100.xxx.xxx.xxx
CHARLIE_URL=100.xxx.xxx.xxx
DELTA_IP=100.xxx.xxx.xxx
DELTA_URL=100.xxx.xxx.xxx
REMOTE_SSH_USER=your_ssh_username
INTERNAL_API_TOKEN=CHANGE_ME_RUN_openssl_rand_hex_32

# ===== ローカルLLM =====
BRAVO_OLLAMA_URL=http://100.xxx.xxx.xxx:11434
CHARLIE_OLLAMA_URL=http://100.xxx.xxx.xxx:11434
DELTA_OLLAMA_URL=http://100.xxx.xxx.xxx:11434
BRAVO_LOCAL_MODEL=qwen3.5:9b
CHARLIE_LOCAL_MODEL=qwen3.5:9b
DELTA_LOCAL_MODEL=qwen3.5:4b

# ===== ブラウザ自動操作4層構成 =====
STAGEHAND_ENV=LOCAL
LIGHTPANDA_PORT=9222
LIGHTPANDA_DISABLE_TELEMETRY=true
CHROMIUM_PORT=9223

# ===== 突然変異エンジン（DELTA専用） =====
SQLCIPHER_PASSPHRASE=CHANGE_ME_RUN_openssl_rand_hex_16

# ===== ログ設定 =====
LOG_LEVEL=INFO
LOG_FILE=logs/syutain_beta.log

# ===== システム設定 =====
TZ=Asia/Tokyo
